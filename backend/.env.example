# Copy to .env and fill in values
NODE_ENV=development
PORT=4000

# --- Frontend URL (required for production; optional locally) ---
# Set these to your deployed Vercel app origin (scheme + host, NO path, NO trailing slash).
# Example production: https://tenantos.vercel.app
#
# FRONTEND_ORIGIN — Who may call this API from a browser (CORS). Must match the tab origin
# where your React app is served (e.g. Vercel). On Render, set this in Environment variables.
# Local dev with Vite:
# FRONTEND_ORIGIN=http://localhost:5173
# Production (replace with your real Vercel URL if different):
# FRONTEND_ORIGIN=https://tenantos.vercel.app
FRONTEND_ORIGIN=http://localhost:5173

# Email verification: false = register returns tokens immediately (typical for local dev).
# Set to true in production when SMTP is configured and you want verify-email + login gate.
# REQUIRE_EMAIL_VERIFICATION=false

# MongoDB connection string (MongoDB Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/tenantos

# Secret for signing JWTs — use a long random string in production (server-only; never expose to clients)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
# Short-lived access token (e.g. 15m). If unset, JWT_EXPIRES_IN is used as fallback.
JWT_ACCESS_EXPIRES_IN=15m
# Deprecated: prefer JWT_ACCESS_EXPIRES_IN
JWT_EXPIRES_IN=7d
# Refresh sessions (opaque tokens stored hashed in DB)
JWT_REFRESH_EXPIRES_DAYS=7
# Email verification link lifetime (hours)
EMAIL_VERIFICATION_EXPIRES_HOURS=24
# Password reset link lifetime (minutes)
PASSWORD_RESET_EXPIRES_MINUTES=60

# APP_PUBLIC_URL — Base URL for links inside emails (invites, verify-email, password reset).
# Same rules: no trailing slash. Tenants open links on your Vercel app (e.g. /tenant/accept?token=...).
# Local:
# APP_PUBLIC_URL=http://localhost:5173
# Production:
# APP_PUBLIC_URL=https://tenantos.vercel.app
APP_PUBLIC_URL=http://localhost:5173
INVITE_EXPIRES_DAYS=7

# --- Outbound email (set at least one: Resend OR SMTP) ---
#
# Option A — Resend (recommended on Render): https://resend.com/api-keys
#   RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # example shape; paste your real key
#   EMAIL_FROM=TenantOS <onboarding@resend.dev>              # Resend’s test sender (OK for first tests)
#   EMAIL_FROM=TenantOS <noreply@mail.yourdomain.com>        # after you verify your domain in Resend
#
RESEND_API_KEY=
EMAIL_FROM=TenantOS <onboarding@resend.dev>

# Option B — SMTP only if RESEND_API_KEY is left empty (e.g. local Gmail)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your_16_char_app_password
#   EMAIL_FROM=TenantOS <you@gmail.com>
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Phase 2 — Paystack (https://dashboard.paystack.com/#/settings/developer)
#
# Webhook (set in Paystack Dashboard → Developers → Webhooks — not in this file):
#   Your deployed API origin + path /api/v1/webhooks/paystack
#   Example: https://tenantos-api.onrender.com/api/v1/webhooks/paystack
#   Example: https://api.mycompany.com/api/v1/webhooks/paystack
# Paystack sends JSON to that URL; the app verifies HMAC using PAYSTACK_SECRET_KEY below.
#
# If Paystack cannot reach your machine (localhost), payments can still record when the tenant returns to
# APP_PUBLIC_URL/tenant — see POST /tenant/paystack/verify. Keep APP_PUBLIC_URL aligned with the Vite app URL.
PAYSTACK_SECRET_KEY=

# Phase 2 — Redis URL for Bull rent reminders (e.g. redis://127.0.0.1:6379)
REDIS_URL=

# Cloudinary — https://cloudinary.com/console (lease documents + landlord property photos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Phase 3 — in-app notifications, org settings, CSV exports (no extra env vars required;
# lease-expiry reminders run inside the same Bull worker as rent reminders when REDIS_URL is set)
