# Copy to .env and fill in values
NODE_ENV=development
PORT=4000

# Optional: restrict CORS to your Vite dev server or deployed app origin
# FRONTEND_ORIGIN=http://localhost:5173

# Email verification: false = register returns tokens immediately (typical for local dev).
# Set to true in production when SMTP is configured and you want verify-email + login gate.
# REQUIRE_EMAIL_VERIFICATION=false

# MongoDB connection string (MongoDB Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/tenantos

# Secret for signing JWTs — use a long random string in production (server-only; never expose to clients)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
# Short-lived access token (e.g. 15m). If unset, JWT_EXPIRES_IN is used as fallback.
JWT_ACCESS_EXPIRES_IN=15m
# Deprecated: prefer JWT_ACCESS_EXPIRES_IN
JWT_EXPIRES_IN=7d
# Refresh sessions (opaque tokens stored hashed in DB)
JWT_REFRESH_EXPIRES_DAYS=7
# Email verification link lifetime (hours)
EMAIL_VERIFICATION_EXPIRES_HOURS=24
# Password reset link lifetime (minutes)
PASSWORD_RESET_EXPIRES_MINUTES=60

# Invite links in emails (no trailing slash). Frontend should handle /tenant/accept?token=
APP_PUBLIC_URL=http://localhost:5173
INVITE_EXPIRES_DAYS=7

# Nodemailer (optional — if SMTP_HOST is empty, invite links are logged to the console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=TenantOS <noreply@localhost>

# Phase 2 — Paystack (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY=

# Phase 2 — Redis URL for Bull rent reminders (e.g. redis://127.0.0.1:6379)
REDIS_URL=

# Cloudinary — https://cloudinary.com/console (lease documents + landlord property photos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Phase 3 — in-app notifications, org settings, CSV exports (no extra env vars required;
# lease-expiry reminders run inside the same Bull worker as rent reminders when REDIS_URL is set)
